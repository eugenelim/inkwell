.DS_Store
bin/
coverage.out
cover.out
*.test
*.prof
*.log
.idea/
.vscode/

# Local regression-by-feature reports (scripts/regress-report.sh).
# Reports are evidence of "ran the suite before tagging" and stay
# local — they are NOT shipped artefacts.
reports/

# Local security scan output (gosec / semgrep / govulncheck).
# Same reasoning as reports/ — kept locally for the operator,
# never committed.
sec-reports/

# Claude Code's project-local settings + scheduled-tasks lockfile.
# Personal to the operator's session; not part of the repo's
# build inputs. The agents/ and skills/ subdirs ARE checked in —
# they're project-level agent contracts (adversarial-reviewer,
# new-spec scaffolder, etc.) shared via the repo.
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/commands/

# Work-loop supervisor-mode scratch (docs/CONVENTIONS.md §12.7).
# Implementer worktrees and their report files are session-local
# — they exist for one EXECUTE phase and may carry uncommitted
# work mid-dispatch. The supervisor merges branches back; the
# scratch directory itself never goes into history.
.worktrees/
docs/specs/**/notes/implementer-*.md

# Per-spec work-loop state (docs/CONVENTIONS.md §12.9). The
# template at docs/_templates/state.json IS checked in; per-spec
# copies are session scratch carrying iteration counts and
# fingerprint history that don't belong in the spec's git trail.
docs/specs/**/state.json
